#Detect any ping (ICMP) to my machine:
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Detected"; sid:9000001; rev:1;)

#Detect SSH brute force attempt (more than 5 connections):
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; flow:to_server; threshold:type threshold, track by_src, count 5, seconds 60; sid:9000002; rev:1;)

#Detect Nmap scan signature:
alert tcp any any -> $HOME_NET any (msg:"Possible Nmap Scan"; flags:S; threshold:type threshold, track by_src, count 20, seconds 5; sid:9000003; rev:1;)
